{
  "name": "matcher-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phase 2 offline replay harness for the Book Effect alignment engine (P1-P5). No Expo/React Native; runs against phase2/corpus.",
  "engines": {
    "node": ">=22.13.0 <23",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "replay": "tsx src/cli/replay.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}
